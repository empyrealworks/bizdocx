rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Does the requested path match the authenticated user's ID?
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Match the user root and all sub-collections (portfolios, documents, context)
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Specific validation for Portfolios (Optional but recommended)
    match /users/{userId}/portfolios/{portfolioId} {
      allow create: if isOwner(userId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
    }
  }
}
